+def _with_images(user_prompt: str, image_blocks: list[dict] | None):
+    """Build a message-content value: images first, then the text prompt (or bare text)."""
+    if image_blocks:
+        return image_blocks + [{"type": "text", "text": user_prompt}]
+    return user_prompt
