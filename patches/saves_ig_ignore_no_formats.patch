From b6ae85e165cec0f6d74054702bd5428c479007c8 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Sat, 13 Jun 2026 23:48:55 +0000
Subject: [PATCH] fix: yt-dlp --ignore-no-formats-error so Instagram image
 posts yield comments

Instagram image posts have no video formats; yt-dlp treated that as fatal,
exited 1, and wrote no info.json -- so image posts always fell back to
gallery-dl, which has no comment support. --ignore-no-formats-error downgrades
the error to a warning so yt-dlp still writes metadata + comments for image
posts, restoring yt-dlp as the primary path with the owner-first-comment capture.

https://claude.ai/code/session_01G3CevLYb6JPcyW363NyKGN
---
 src/extractors/instagram.py | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/src/extractors/instagram.py b/src/extractors/instagram.py
index c79ea16..0037bd9 100644
--- a/src/extractors/instagram.py
+++ b/src/extractors/instagram.py
@@ -82,8 +82,12 @@ class InstagramExtractor(BaseExtractor):
         with tempfile.TemporaryDirectory() as tmpdir:
             cookies_path = os.path.join(self.cookies_dir, "instagram.txt")
             cookies_exist = os.path.exists(cookies_path)
+            # Instagram image posts have no video formats, which yt-dlp treats as a
+            # fatal error and then writes no info.json (and no comments). The
+            # --ignore-no-formats-error flag downgrades that to a warning so yt-dlp
+            # still produces the metadata + comments for image posts.
             cmd = ["yt-dlp", "--write-info-json", "--write-comments",
-                   "--skip-download", "--no-warnings",
+                   "--skip-download", "--no-warnings", "--ignore-no-formats-error",
                    "-o", os.path.join(tmpdir, "%(id)s.%(ext)s")]
             if cookies_exist:
                 cmd += ["--cookies", cookies_path]
-- 
